<Window x:Class="CarCare360.Desktop.Views.ClientEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Border Padding="28,24">
        <StackPanel>

            <!-- Заголовок диалога -->
            <TextBlock Text="{Binding Title}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                       Margin="0,0,0,20" />

            <!-- ── Полное имя (обязательно) ── -->
            <TextBlock Text="Полное имя *"
                       FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     Margin="0,0,0,12" />

            <!-- ── Логин (обязательно; только для чтения при редактировании) ── -->
            <TextBlock Text="Логин *"
                       FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource ThemedTextBoxStyle}">
                        <Style.Triggers>
                            <!-- При редактировании логин заблокирован визуально -->
                            <DataTrigger Binding="{Binding IsNewClient}" Value="False">
                                <Setter Property="Background" Value="#F0F0F0" />
                                <Setter Property="IsReadOnly" Value="True" />
                                <Setter Property="Foreground" Value="#888" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- ── Пароль (только для нового клиента) ── -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNewClient}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Пароль *"
                           FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordInput"
                             Style="{StaticResource ThemedPasswordBoxStyle}"
                             PasswordChanged="PasswordInput_PasswordChanged"
                             Margin="0,0,0,12" />
                <TextBlock Text="Запомните пароль — его нельзя будет просмотреть позже."
                           FontSize="11" Foreground="#888" Margin="0,-6,0,12" />
            </StackPanel>

            <!-- ── Телефон ── -->
            <TextBlock Text="Телефон"
                       FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     Margin="0,0,0,12" />

            <!-- ── Email ── -->
            <TextBlock Text="Email"
                       FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     Margin="0,0,0,18" />

            <!-- ── Сообщение об ошибке ── -->
            <Border Background="#FFEBEE"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ── Кнопки ── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Отмена -->
                <Button Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Width="90" Height="36"
                        Margin="0,0,10,0"
                        FontSize="13"
                        Background="White"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Сохранить -->
                <Button Content="Сохранить"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Width="110" Height="36"
                        FontSize="13"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
