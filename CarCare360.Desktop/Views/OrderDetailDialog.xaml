<Window x:Class="CarCare360.Desktop.Views.OrderDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarCare360.Desktop.ViewModels"
        Title="Детали заказ-наряда"
        Width="880" Height="720"
        MinWidth="700" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource LightBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBlueBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#222222" />
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DangerSmallBtn" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="#D32F2F" />
        </Style>
        <Style x:Key="BlueSmallBtn" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryDarkBlueBrush}" />
        </Style>
        <Style x:Key="AddPanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#E8EAF6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Шапка с инфо -->
            <RowDefinition Height="*"    /> <!-- Прокручиваемое содержимое -->
            <RowDefinition Height="Auto" /> <!-- Итоги + кнопка закрыть -->
        </Grid.RowDefinitions>

        <!-- ══ Шапка ═════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Заголовок: № заказа + данные -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryDarkBlueBrush}">
                        <Run Text="Заказ #" />
                        <Run Text="{Binding OrderId, Mode=OneWay}" />
                    </TextBlock>

                    <Rectangle Width="1" Fill="{StaticResource BorderGrayBrush}" Margin="16,2" />

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource InfoLabel}" Text="Клиент" />
                        <TextBlock Style="{StaticResource InfoValue}"
                                   Text="{Binding ClientName}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryDarkBlueBrush}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource InfoLabel}" Text="Автомобиль" />
                        <TextBlock Style="{StaticResource InfoValue}"
                                   Text="{Binding CarInfo}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Style="{StaticResource InfoLabel}" Text="Создан" />
                        <TextBlock Style="{StaticResource InfoValue}"
                                   Text="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка обновить -->
                <Button Grid.Column="1"
                        Content="↻"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource BlueSmallBtn}"
                        Width="36"
                        ToolTip="Обновить"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ══ Прокручиваемое тело ════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="24,16,24,16">

                <!-- Баг 2 — баннер «только для чтения» для финальных статусов.
                     Виден только когда IsReadOnly=True (Готов / Выдан / Отменён). -->
                <Border Background="#FFF3E0"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,14"
                        BorderBrush="#FFB300"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="15" Foreground="#E65100"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Заказ закрыт — редактирование недоступно."
                                   FontSize="13" Foreground="#E65100"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── Статус + дата/время + примечания ───────────────────── -->
                <Border Background="White" CornerRadius="6" Padding="16,14"
                        Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"   />
                            <ColumnDefinition Width="12"  />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="12"  />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="12"  />
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Статус -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Статус" FontSize="11" Foreground="#888888" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{x:Static vm:OrderDetailViewModel.EditableStatuses}"
                                          SelectedItem="{Binding CurrentStatus}"
                                          Padding="8,6" FontSize="13"
                                          VerticalContentAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="Сохранить"
                                        Command="{Binding ChangeStatusCommand}"
                                        Style="{StaticResource SmallBtn}" />
                            </Grid>
                        </StackPanel>

                        <!-- Дата -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Дата (ДД.ММ.ГГГГ)" FontSize="11" Foreground="#888888" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                                     Text="{Binding ScheduledDate, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="10" Padding="8,6" />
                        </StackPanel>

                        <!-- Время -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Время (ЧЧ:ММ)" FontSize="11" Foreground="#888888" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                                     Text="{Binding ScheduledTime, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="5" Padding="8,6" />
                        </StackPanel>

                        <!-- Сохранить заголовок -->
                        <Button Grid.Column="6"
                                Content="💾 Сохранить"
                                Command="{Binding SaveHeaderCommand}"
                                Style="{StaticResource BlueSmallBtn}"
                                VerticalAlignment="Bottom" />
                    </Grid>
                </Border>

                <!-- Примечания -->
                <Border Background="White" CornerRadius="6" Padding="16,14"
                        Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Примечания" FontSize="11" Foreground="#888888" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="60"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>
                </Border>

                <!-- Блок ошибки -->
                <Border Background="#FFEBEE" CornerRadius="4" Padding="12,8"
                        Margin="0,0,0,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorRedBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </Border>

                <!-- ── Секция «Услуги» ─────────────────────────────────────── -->
                <Border Background="White" CornerRadius="6" Padding="16,14"
                        Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Заголовок услуг + кнопки -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Услуги" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="＋ Добавить"
                                        Command="{Binding ShowAddServiceCommand}"
                                        Style="{StaticResource SmallBtn}"
                                        Margin="0,0,8,0" />
                                <Button Content="✕ Удалить"
                                        Command="{Binding RemoveServiceCommand}"
                                        Style="{StaticResource DangerSmallBtn}" />
                            </StackPanel>
                        </Grid>

                        <!-- DataGrid услуг -->
                        <DataGrid ItemsSource="{Binding ServiceLines}"
                                  SelectedItem="{Binding SelectedServiceLine}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderGrayBrush}"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  MinHeight="60"
                                  MaxHeight="200"
                                  FontSize="12">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F5F5" />
                                    <Setter Property="Foreground" Value="#666666" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="8,6" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceName}" Width="*" />
                                <DataGridTextColumn Header="Механик" Binding="{Binding MechanicName}" Width="150" />
                                <DataGridTextColumn Header="Бокс" Binding="{Binding BayName}" Width="110" />
                                <DataGridTextColumn Header="Статус" Binding="{Binding LineStatus}" Width="100" />
                                <DataGridTextColumn Header="Цена, ₽"
                                                    Binding="{Binding Price, StringFormat=\{0:N0\}}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                            <Setter Property="Margin" Value="0,0,6,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Панель добавления услуги -->
                        <Border Style="{StaticResource AddPanelBorder}"
                                Visibility="{Binding IsAddingService, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"   />
                                    <ColumnDefinition Width="12"  />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="12"  />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Услуга" FontSize="11" Foreground="#666666" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="2" Text="Механик" FontSize="11" Foreground="#666666" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="4" Text="Бокс" FontSize="11" Foreground="#666666" Margin="0,0,0,4" />

                                <ComboBox Grid.Row="2" Grid.Column="0"
                                          ItemsSource="{Binding AvailableServices}"
                                          SelectedItem="{Binding SelectedNewService}"
                                          DisplayMemberPath="Name"
                                          Padding="8,6" FontSize="12"
                                          VerticalContentAlignment="Center" />

                                <ComboBox Grid.Row="2" Grid.Column="2"
                                          ItemsSource="{Binding AvailableMechanics}"
                                          SelectedItem="{Binding SelectedNewMechanic}"
                                          DisplayMemberPath="FullName"
                                          Padding="8,6" FontSize="12"
                                          VerticalContentAlignment="Center" />

                                <ComboBox Grid.Row="2" Grid.Column="4"
                                          ItemsSource="{Binding AvailableBays}"
                                          SelectedItem="{Binding SelectedNewBay}"
                                          DisplayMemberPath="Name"
                                          Padding="8,6" FontSize="12"
                                          VerticalContentAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Кнопки подтверждения добавления услуги -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Visibility="{Binding IsAddingService, Converter={StaticResource BoolToVisibility}}">
                            <Button Content="Отмена"
                                    Command="{Binding CancelAddServiceCommand}"
                                    Style="{StaticResource SmallBtn}"
                                    Background="{StaticResource PrimaryDarkBlueBrush}"
                                    Margin="0,0,8,0" />
                            <Button Content="✔ Добавить услугу"
                                    Command="{Binding ConfirmAddServiceCommand}"
                                    Style="{StaticResource SmallBtn}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Секция «Запчасти» ───────────────────────────────────── -->
                <Border Background="White" CornerRadius="6" Padding="16,14"
                        Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Заголовок запчастей + кнопки -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Запчасти" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="＋ Добавить"
                                        Command="{Binding ShowAddPartCommand}"
                                        Style="{StaticResource SmallBtn}"
                                        Margin="0,0,8,0" />
                                <Button Content="✕ Удалить"
                                        Command="{Binding RemovePartCommand}"
                                        Style="{StaticResource DangerSmallBtn}" />
                            </StackPanel>
                        </Grid>

                        <!-- DataGrid запчастей -->
                        <DataGrid ItemsSource="{Binding PartLines}"
                                  SelectedItem="{Binding SelectedPartLine}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderGrayBrush}"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  MinHeight="60"
                                  MaxHeight="180"
                                  FontSize="12">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F5F5" />
                                    <Setter Property="Foreground" Value="#666666" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="8,6" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Запчасть" Binding="{Binding PartName}" Width="*" />
                                <DataGridTextColumn Header="Кол-во"
                                                    Binding="{Binding Quantity}"
                                                    Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Цена, ₽"
                                                    Binding="{Binding PricePerUnit, StringFormat=\{0:N0\}}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                            <Setter Property="Margin" Value="0,0,6,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Итого, ₽"
                                                    Binding="{Binding Total, StringFormat=\{0:N0\}}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Margin" Value="0,0,6,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Панель добавления запчасти -->
                        <Border Style="{StaticResource AddPanelBorder}"
                                Visibility="{Binding IsAddingPart, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"   />
                                    <ColumnDefinition Width="12"  />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8"    />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Запчасть (со склада)" FontSize="11" Foreground="#666666" Margin="0,0,0,4" />
                                <TextBlock Grid.Column="2" Text="Количество" FontSize="11" Foreground="#666666" Margin="0,0,0,4" />

                                <ComboBox Grid.Row="2" Grid.Column="0"
                                          ItemsSource="{Binding AvailableParts}"
                                          SelectedItem="{Binding SelectedNewPart}"
                                          Padding="8,6" FontSize="12"
                                          VerticalContentAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding Name,  Mode=OneWay}" />
                                                <Run Text=" (" Foreground="#AAAAAA" />
                                                <Run Text="{Binding Stock, Mode=OneWay}" Foreground="#AAAAAA" />
                                                <Run Text=" шт.)" Foreground="#AAAAAA" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBox Grid.Row="2" Grid.Column="2"
                                         Style="{StaticResource ThemedTextBoxStyle}"
                                         Text="{Binding NewPartQty, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6"
                                         HorizontalContentAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Кнопки подтверждения добавления запчасти -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Visibility="{Binding IsAddingPart, Converter={StaticResource BoolToVisibility}}">
                            <Button Content="Отмена"
                                    Command="{Binding CancelAddPartCommand}"
                                    Style="{StaticResource SmallBtn}"
                                    Background="{StaticResource PrimaryDarkBlueBrush}"
                                    Margin="0,0,8,0" />
                            <Button Content="✔ Добавить запчасть"
                                    Command="{Binding ConfirmAddPartCommand}"
                                    Style="{StaticResource SmallBtn}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ Итоги + кнопка закрыть ═════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Итоги -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="Услуги" FontSize="11" Foreground="#888888" />
                        <TextBlock FontSize="15" FontWeight="SemiBold">
                            <Run Text="{Binding ServicesTotalCost, StringFormat=\{0:N0\}, Mode=OneWay}" />
                            <Run Text=" ₽" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="+" FontSize="18" Foreground="#BBBBBB"
                               VerticalAlignment="Center" Margin="0,0,32,0" />
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="Запчасти" FontSize="11" Foreground="#888888" />
                        <TextBlock FontSize="15" FontWeight="SemiBold">
                            <Run Text="{Binding PartsTotalCost, StringFormat=\{0:N0\}, Mode=OneWay}" />
                            <Run Text=" ₽" />
                        </TextBlock>
                    </StackPanel>
                    <Rectangle Width="1" Fill="{StaticResource BorderGrayBrush}" Margin="0,2" />
                    <StackPanel Margin="32,0,0,0">
                        <TextBlock Text="ИТОГО" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryDarkBlueBrush}" />
                        <TextBlock FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentOrangeBrush}">
                            <Run Text="{Binding GrandTotal, StringFormat=\{0:N0\}, Mode=OneWay}" />
                            <Run Text=" ₽" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка закрыть -->
                <Button Grid.Column="1"
                        Content="  Закрыть  "
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource PrimaryDarkBlueBrush}"
                        Height="40" FontSize="14"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
