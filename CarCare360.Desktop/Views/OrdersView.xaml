<UserControl x:Class="CarCare360.Desktop.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CarCare360.Desktop.Views"
             Background="{StaticResource LightBackgroundBrush}">

    <UserControl.Resources>
        <!-- Стиль чипа-фильтра статуса -->
        <Style x:Key="StatusChipStyle" TargetType="Button">
            <Setter Property="Background"       Value="#F5F5F5"/>
            <Setter Property="Foreground"       Value="#424242"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Margin"           Value="0,0,6,0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Маленькая кнопка действия в карточке -->
        <Style x:Key="CardActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="10,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Заголовок + кнопки -->
            <RowDefinition Height="Auto" />  <!-- Строка поиска -->
            <RowDefinition Height="Auto" />  <!-- Чипы статусов -->
            <RowDefinition Height="*"    />  <!-- Карточки / Skeleton -->
            <RowDefinition Height="Auto" />  <!-- Статусбар -->
        </Grid.RowDefinitions>

        <!-- ════ Заголовок + кнопки ════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                               FontSize="24" VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryDarkBlueBrush}"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="Заказы"
                               FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryDarkBlueBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource NeutralButtonStyle}"
                            Width="38" Padding="0"
                            ToolTip="Обновить" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding CreateCommand}"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Новый заказ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════ Поиск + чекбокс ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#F5F5F5"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="4,0" MaxWidth="440"
                        HorizontalAlignment="Left" Width="440">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center"
                                   Margin="8,0,0,0" Foreground="#888"
                                   IsHitTestVisible="False"/>
                        <Grid Width="360">
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     FontSize="13" Padding="6,8"/>
                            <TextBlock Text="Поиск по клиенту, авто или №..."
                                       Foreground="#AAAAAA" FontSize="13"
                                       VerticalAlignment="Center" Margin="6,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="✕" HorizontalAlignment="Right"
                                    Width="24" FontSize="11" Foreground="#999"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" VerticalAlignment="Center"
                                    Click="ClearSearch_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <CheckBox Grid.Column="1"
                          Content="Показывать удалённые"
                          IsChecked="{Binding ShowDeleted}"
                          VerticalAlignment="Center" Margin="16,0,0,0"
                          FontSize="13" Foreground="#666"/>
            </Grid>
        </Border>

        <!-- ════ Чипы фильтров статусов ════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,10">
            <WrapPanel>
                <!-- Все -->
                <Button Content="Все"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Все">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Все">
                                    <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Новый -->
                <Button Content="Новый"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Новый">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Новый">
                                    <Setter Property="Background" Value="#2196F3"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- В работе -->
                <Button Content="В работе"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="В работе">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="В работе">
                                    <Setter Property="Background" Value="#FFC107"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Ожидает запчасти -->
                <Button Content="Ожидает запчасти"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Ожидает запчасти">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Ожидает запчасти">
                                    <Setter Property="Background" Value="#9C27B0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Готов -->
                <Button Content="Готов"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Готов">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Готов">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Выдан -->
                <Button Content="Выдан"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Выдан">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Выдан">
                                    <Setter Property="Background" Value="#607D8B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Отменён -->
                <Button Content="Отменён"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="Отменён">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StatusChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusFilter}" Value="Отменён">
                                    <Setter Property="Background" Value="#F44336"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
        </Border>

        <!-- ════ Skeleton-заглушка ══════════════════════════════════════════ -->
        <views:SkeletonLoading Grid.Row="3"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- ════ Карточки заказов ═══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Orders}" Margin="24,16,24,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Карточка заказа -->
                        <Border Width="290" Margin="0,0,16,16"
                                CornerRadius="12" Padding="16"
                                Background="White"
                                BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.12"
                                                  ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Заголовок + статус -->
                                    <RowDefinition Height="Auto"/> <!-- Клиент -->
                                    <RowDefinition Height="Auto"/> <!-- Авто -->
                                    <RowDefinition Height="Auto"/> <!-- Дата создания + запланировано -->
                                    <RowDefinition Height="Auto"/> <!-- Разделитель -->
                                    <RowDefinition Height="Auto"/> <!-- Сумма + кнопки -->
                                </Grid.RowDefinitions>

                                <!-- Заголовок: «Заказ #N» + статус-метка -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                               VerticalAlignment="Center">
                                        <Run Text="Заказ #"/>
                                        <Run Text="{Binding OrderID}"/>
                                    </TextBlock>

                                    <!-- Статус-метка -->
                                    <Border Grid.Column="1" CornerRadius="8" Padding="7,3"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Новый">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Ожидает запчасти">
                                                        <Setter Property="Background" Value="#FCE4EC"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Готов">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Выдан">
                                                        <Setter Property="Background" Value="#E0F2F1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Новый">
                                                            <Setter Property="Foreground" Value="#1565C0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                            <Setter Property="Foreground" Value="#E65100"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ожидает запчасти">
                                                            <Setter Property="Foreground" Value="#AD1457"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Готов">
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Выдан">
                                                            <Setter Property="Foreground" Value="#00695C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Клиент -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding ClientFullName}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,3"/>

                                <!-- Авто -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding CarInfo}"
                                           FontSize="12" Foreground="#666"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,8"/>

                                <!-- Даты -->
                                <Grid Grid.Row="3" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Создан" FontSize="10" Foreground="#999"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                                   FontSize="12" Foreground="#444"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Запланировано" FontSize="10" Foreground="#999"/>
                                        <TextBlock FontSize="12" Foreground="#444">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="—"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ScheduledDate}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.Text>
                                                <Binding Path="ScheduledDate" StringFormat="dd.MM.yyyy"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- Разделитель -->
                                <Border Grid.Row="4" Height="1"
                                        Background="{StaticResource BorderGrayBrush}"
                                        Margin="0,0,0,10"/>

                                <!-- Сумма + кнопки действий -->
                                <Grid Grid.Row="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Сумма -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TotalCost, StringFormat={}{0:N0} ₽}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentOrangeBrush}"/>
                                        <TextBlock FontSize="10" Foreground="#999">
                                            <Run Text="{Binding ServiceCount}"/>
                                            <Run Text=" усл."/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding PartCount}"/>
                                            <Run Text=" зап."/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Кнопки -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Открыть"
                                                Command="{Binding DataContext.OpenCardCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{StaticResource AccentOrangeBrush}"
                                                Foreground="White"
                                                Style="{StaticResource CardActionButtonStyle}"
                                                Margin="0,0,6,0"/>
                                        <Button Command="{Binding DataContext.DeleteCardCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CardActionButtonStyle}">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ════ Статусбар ══════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,6">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right"
                             Width="120" Height="3"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
