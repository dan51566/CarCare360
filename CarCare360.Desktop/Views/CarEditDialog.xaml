<Window x:Class="CarCare360.Desktop.Views.CarEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Border Padding="28,24">
        <StackPanel>

            <!-- Заголовок -->
            <TextBlock Text="{Binding Title}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                       Margin="0,0,0,20" />

            <!-- ── Владелец ── -->
            <TextBlock Text="Владелец *" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding SelectedClient}"
                      Height="36" FontSize="13"
                      Margin="0,0,0,4">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Phone, StringFormat=' ({0})'}"
                                       Foreground="#777" Margin="4,0,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="(только активные клиенты)"
                       FontSize="11" Foreground="#888" Margin="0,0,0,12" />

            <!-- ── Марка и Модель (2 колонки) ── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Марка *" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Brands}"
                              SelectedItem="{Binding SelectedBrand}"
                              DisplayMemberPath="Name"
                              Height="36" FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Модель *" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Models}"
                              SelectedItem="{Binding SelectedModel}"
                              DisplayMemberPath="Name"
                              Height="36" FontSize="13">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBrand}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- ── Гос. номер и Год (2 колонки) ── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Гос. номер *" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <TextBox Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemedTextBoxStyle}"
                             CharacterCasing="Upper"
                             MaxLength="9"
                             FontFamily="Consolas"
                             FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Год выпуска" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <TextBox Text="{Binding YearText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemedTextBoxStyle}"
                             MaxLength="4" />
                </StackPanel>
            </Grid>

            <!-- ── VIN ── -->
            <TextBlock Text="VIN (17 символов)" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
            <TextBox Text="{Binding VIN, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     CharacterCasing="Upper"
                     MaxLength="17"
                     FontFamily="Consolas"
                     Margin="0,0,0,12" />

            <!-- ── Цвет и Пробег (2 колонки) ── -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Цвет" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemedTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Пробег (км)" FontSize="13" Foreground="#444" Margin="0,0,0,4" />
                    <TextBox Text="{Binding MileageText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemedTextBoxStyle}" />
                </StackPanel>
            </Grid>

            <!-- ── Ошибка ── -->
            <Border Background="#FFEBEE" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="12" TextWrapping="Wrap" />
            </Border>

            <!-- ── Кнопки ── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Width="90" Height="36" Margin="0,0,10,0"
                        FontSize="13" Background="White"
                        BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#F5F5F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Сохранить"
                        Command="{Binding SaveCommand}"
                        IsDefault="True"
                        Width="110" Height="36"
                        FontSize="13"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
