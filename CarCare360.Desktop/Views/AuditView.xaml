<UserControl x:Class="CarCare360.Desktop.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:CarCare360.Desktop.ViewModels"
             xmlns:views="clr-namespace:CarCare360.Desktop.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Background="{StaticResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Заголовок -->
            <RowDefinition Height="Auto" />  <!-- Фильтры -->
            <RowDefinition Height="*"    />  <!-- DataGrid / Skeleton -->
            <RowDefinition Height="Auto" />  <!-- Кнопка «Загрузить ещё» -->
            <RowDefinition Height="Auto" />  <!-- Статусбар -->
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                           FontSize="24" VerticalAlignment="Center"
                           Foreground="{StaticResource PrimaryDarkBlueBrush}"
                           Margin="0,0,12,0"/>
                <TextBlock Text="Журнал аудита" FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryDarkBlueBrush}" />
            </StackPanel>
        </Border>

        <!-- ══ Панель фильтров ══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кто изменил -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Кто изменил:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                    <Border BorderBrush="{StaticResource BorderGrayBrush}"
                            BorderThickness="1" CornerRadius="6" Width="160">
                        <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                                 BorderThickness="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>

                <!-- Таблица -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Объект:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                    <ComboBox Width="130" VerticalAlignment="Center"
                              ItemsSource="{x:Static vm:AuditViewModel.AllTables}"
                              SelectedItem="{Binding SelectedTable}"/>
                </StackPanel>

                <!-- Операция -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Операция:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                    <ComboBox Width="90" VerticalAlignment="Center"
                              ItemsSource="{x:Static vm:AuditViewModel.AllOperations}"
                              SelectedItem="{Binding SelectedOperation}"/>
                </StackPanel>

                <!-- Дата от -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="С:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                    <DatePicker Width="130" VerticalAlignment="Center"
                                SelectedDate="{Binding DateFrom, TargetNullValue={x:Null}}"
                                SelectedDateFormat="Short"/>
                </StackPanel>

                <!-- Дата до -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="По:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                    <DatePicker Width="130" VerticalAlignment="Center"
                                SelectedDate="{Binding DateTo, TargetNullValue={x:Null}}"
                                SelectedDateFormat="Short"/>
                </StackPanel>

                <!-- Применить -->
                <Button Grid.Column="10" Content="▶  Применить" Command="{Binding ApplyCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ Skeleton / DataGrid ════════════════════════════════════════ -->

        <views:SkeletonLoading Grid.Row="2" Margin="16,8,16,0"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Logs}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  RowBackground="White" BorderThickness="0"
                  CanUserResizeRows="False" CanUserReorderColumns="False"
                  RowDetailsVisibilityMode="Collapsed"
                  FontSize="13" Margin="16,8,16,0"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#3F51B5"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#C5CAE9"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#212121"/>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBlueBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,10"/>
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="BorderBrush" Value="#283593"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.Resources>

            <!-- RowStyle: высота + раскрытие RowDetails по IsExpanded -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="36"/>
                    <Setter Property="DetailsVisibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="DetailsVisibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- RowDetailsTemplate — diff-таблица при раскрытии строки -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F5F7FF"
                            BorderBrush="#C5CAE9"
                            BorderThickness="0,1,0,1"
                            Padding="20,12">
                        <StackPanel>

                            <!-- Заголовок diff-секции -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#3F51B5"
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Изменённые поля"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Operation}" Value="I">
                                                <Setter Property="Text" Value="Добавленная запись"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Operation}" Value="D">
                                                <Setter Property="Text" Value="Удалённая запись"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Шапка таблицы (только для UPDATE) -->
                            <Grid Margin="0,0,0,4">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Operation}" Value="U">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Поле"
                                           FontSize="10" Foreground="#888" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Было"
                                           FontSize="10" Foreground="#888" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Стало"
                                           FontSize="10" Foreground="#888" FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Строки diff -->
                            <ItemsControl ItemsSource="{Binding DiffLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DEE2F5" BorderThickness="0,0,0,1"
                                                Padding="0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Название поля -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Field}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#444"
                                                           VerticalAlignment="Center"/>

                                                <!-- Старое значение (красный) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding OldValue}"
                                                           FontSize="12"
                                                           Foreground="#C62828"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding OldValue}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Стрелка → (только если оба значения есть) -->
                                                <TextBlock Grid.Column="2"
                                                           Text="→"
                                                           FontSize="12" Foreground="#888"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding OldValue}" Value=""/>
                                                                    </MultiDataTrigger.Conditions>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Новое значение (зелёный) -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding NewValue}"
                                                           FontSize="12"
                                                           Foreground="#2E7D32"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding NewValue}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Нет деталей -->
                            <TextBlock Text="Подробности изменений недоступны"
                                       FontSize="12" Foreground="#AAAAAA" Margin="0,4,0,0"
                                       Visibility="{Binding HasDiffLines,
                                                    Converter={StaticResource InverseBoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>

            <DataGrid.Columns>

                <!-- Кнопка раскрытия ▶ / ▼ -->
                <DataGridTemplateColumn Width="36" Header="" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Width="22" Height="22" Padding="0" FontSize="9"
                                    Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}"
                                    Command="{Binding DataContext.ToggleExpandCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding LogID}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                                        <Setter Property="Content" Value="▶"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Content" Value="▼"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Когда -->
                <DataGridTextColumn Header="Когда"
                                    Binding="{Binding ChangedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}"
                                    Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#555555"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Кто изменил -->
                <DataGridTextColumn Header="Кто изменил" Binding="{Binding ChangedBy}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Объект (таблица) -->
                <DataGridTextColumn Header="Объект" Binding="{Binding TableDisplayName}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Операция — цветная метка с русским названием -->
                <DataGridTemplateColumn Header="Операция" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="10,3"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="2,0"
                                    Background="{Binding Operation,
                                        Converter={StaticResource AuditOpColor}}">
                                <TextBlock Text="{Binding Operation,
                                               Converter={StaticResource AuditOpText}}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Краткое описание изменения -->
                <DataGridTextColumn Header="Что изменилось" Binding="{Binding ChangeSummary}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#444"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ══ Кнопка «Загрузить ещё» ════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8"
                Visibility="{Binding HasMore, Converter={StaticResource BoolToVisibility}}">
            <Button Content="↓  Загрузить ещё"
                    Command="{Binding LoadMoreCommand}"
                    Style="{StaticResource NeutralButtonStyle}"
                    HorizontalAlignment="Center"/>
        </Border>

        <!-- ══ Статусбар ══════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0" Padding="24,8">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right" Width="120" Height="4"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
