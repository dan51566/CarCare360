<UserControl x:Class="CarCare360.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:CarCare360.Desktop.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- Стиль чипа вкладки -->
        <Style x:Key="ReportTabChipStyle" TargetType="Button">
            <Setter Property="Background"             Value="#F5F5F5"/>
            <Setter Property="Foreground"             Value="#555555"/>
            <Setter Property="FontSize"               Value="13"/>
            <Setter Property="FontWeight"             Value="Regular"/>
            <Setter Property="Padding"                Value="20,8"/>
            <Setter Property="Margin"                 Value="0,0,8,0"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E8EAF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Заголовок + период + экспорт -->
            <RowDefinition Height="Auto" />  <!-- Чипы вкладок -->
            <RowDefinition Height="Auto" />  <!-- Прогресс-бар -->
            <RowDefinition Height="*"    />  <!-- Контент -->
            <RowDefinition Height="Auto" />  <!-- Статусбар -->
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                               FontSize="24" VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryDarkBlueBrush}"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="Отчёты и дашборд" FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryDarkBlueBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Период:" VerticalAlignment="Center"
                               FontSize="13" Foreground="#555" Margin="0,0,8,0"/>
                    <ComboBox Width="140" VerticalAlignment="Center" Margin="0,0,12,0"
                              ItemsSource="{x:Static vm:ReportsViewModel.PeriodOptions}"
                              SelectedItem="{Binding SelectedPeriod}"/>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportExcelCommand}"
                            Style="{StaticResource NeutralButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7B5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Экспорт Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Чипы вкладок ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="24,12">
            <StackPanel Orientation="Horizontal">

                <!-- Чип «Финансы» (index=0) -->
                <Button Command="{Binding SelectTabCommand}" CommandParameter="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Финансы" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedReportTab}" Value="0">
                                    <Setter Property="Background"
                                            Value="{StaticResource PrimaryDarkBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Чип «Механики» (index=1) -->
                <Button Command="{Binding SelectTabCommand}" CommandParameter="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE90D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Механики" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedReportTab}" Value="1">
                                    <Setter Property="Background"
                                            Value="{StaticResource PrimaryDarkBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══ Индикатор загрузки ══════════════════════════════════════════ -->
        <ProgressBar Grid.Row="2" Height="3" IsIndeterminate="True"
                     Background="Transparent"
                     Foreground="{StaticResource PrimaryDarkBlueBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- ══ Контент ════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,16,24,16">

                <!-- ── Вкладка «Финансы» (SelectedReportTab=0) ───────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedReportTab}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- KPI-карточки -->
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,24">

                        <!-- Заказов за период -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="200" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Заказов за период"/>
                                </TextBlock>
                                <TextBlock Text="{Binding TotalOrders}"
                                           FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryDarkBlueBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Выручка -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="220" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Выручка, ₽"/>
                                </TextBlock>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat=\{0:N0\}}"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrangeBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Новых клиентов -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="200" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE716;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Новых клиентов"/>
                                </TextBlock>
                                <TextBlock Text="{Binding NewClientsCount}"
                                           FontSize="36" FontWeight="Bold"
                                           Foreground="#1565C0"/>
                            </StackPanel>
                        </Border>

                        <!-- Активных механиков -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="220" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE90D;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Активных механиков"/>
                                </TextBlock>
                                <TextBlock Text="{Binding ActiveMechanicsCount}"
                                           FontSize="36" FontWeight="Bold"
                                           Foreground="#2E7D32"/>
                            </StackPanel>
                        </Border>

                        <!-- Позиций с низким остатком -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="230" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Низкий остаток (&#x2264; 5)"/>
                                </TextBlock>
                                <TextBlock Text="{Binding LowStockCount}"
                                           FontSize="36" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Стоимость склада -->
                        <Border CornerRadius="10" Background="White" Padding="20,16"
                                Width="240" Margin="0,0,16,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="#888"
                                           TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets"/>
                                    <Run Text="  Стоимость склада, ₽"/>
                                </TextBlock>
                                <TextBlock Text="{Binding WarehouseTotalValue, StringFormat=\{0:N0\}}"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="#555555"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                    <!-- Заказы по статусам -->
                    <Border Background="White" CornerRadius="10" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Заказы по статусам" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                       Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding OrdersByStatus}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FAFAFA"
                                      RowBackground="White"
                                      BorderThickness="0"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      FontSize="13">
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#3F51B5"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource PrimaryDarkBlueBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,10"/>
                                        <Setter Property="Height" Value="38"/>
                                        <Setter Property="BorderBrush" Value="#283593"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Height" Value="36"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Статус" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="10,3"
                                                        HorizontalAlignment="Left" Margin="4,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#EEEEEE"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Новый">
                                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Назначен">
                                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Ожидает запчасти">
                                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Готов">
                                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Выдан">
                                                                    <Setter Property="Background" Value="#F3E5F5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Отменён">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="12"
                                                               FontWeight="SemiBold" Foreground="#444444"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Count}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="14"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Баг 5 — блок графиков Finance-вкладки. -->

                    <!-- Столбчатый график: Выручка по дням (Услуги + Запчасти) -->
                    <Border Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Выручка по дням"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                       Margin="0,0,0,10"/>
                            <lvc:CartesianChart Series="{Binding RevenueSeries}"
                                                XAxes="{Binding RevenueXAxes}"
                                                Height="220"
                                                LegendPosition="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Нижняя строка: Donut-диаграмма + Линейный график среднего чека -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Структура доходов (Donut) -->
                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Структура доходов"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                           Margin="0,0,0,10"/>
                                <lvc:PieChart Series="{Binding StructureSeries}"
                                              Height="200"
                                              InitialRotation="-90"
                                              MaxAngle="360"
                                              LegendPosition="Bottom"/>
                            </StackPanel>
                        </Border>

                        <!-- Средний чек по дням (Line) -->
                        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Сумма по заказам (по дням)"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                           Margin="0,0,0,10"/>
                                <lvc:CartesianChart Series="{Binding AvgCheckSeries}"
                                                    XAxes="{Binding RevenueXAxes}"
                                                    Height="200"
                                                    LegendPosition="Right"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>

                <!-- ── Вкладка «Механики» (SelectedReportTab=1) ──────── -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedReportTab}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Border Background="White" CornerRadius="10" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Нагрузка механиков" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                       Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding MechanicStats}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FAFAFA"
                                      RowBackground="White"
                                      BorderThickness="0"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      FontSize="13">
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#3F51B5"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource PrimaryDarkBlueBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,10"/>
                                        <Setter Property="Height" Value="38"/>
                                        <Setter Property="BorderBrush" Value="#283593"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Height" Value="40"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>

                                    <!-- Механик -->
                                    <DataGridTextColumn Header="Механик" Binding="{Binding FullName}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Кол-во заказов -->
                                    <DataGridTextColumn Header="Заказов" Binding="{Binding OrdersCount}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBlueBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Сумма услуг -->
                                    <DataGridTextColumn Header="Сумма услуг, ₽"
                                                        Binding="{Binding ServicesTotal, StringFormat=\{0:N0\}}"
                                                        Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="0,0,12,0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Ср. время (дней) -->
                                    <DataGridTextColumn Header="Ср. время (дн.)"
                                                        Binding="{Binding AvgDays, StringFormat=\{0:F1\}}"
                                                        Width="115">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Активных заказов -->
                                    <DataGridTemplateColumn Header="Активных" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="8,3"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ActiveOrders}" Value="0">
                                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding ActiveOrders}"
                                                               FontWeight="SemiBold" FontSize="13">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ActiveOrders}" Value="0">
                                                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </ScrollViewer>

        <!-- ══ Статусбар ══════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0" Padding="24,6">
            <TextBlock Foreground="#888888" FontSize="11"
                       Text="Данные рассчитаны по выбранному периоду. Нажмите ↻ для обновления."/>
        </Border>
    </Grid>
</UserControl>
