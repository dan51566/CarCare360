<Window x:Class="CarCare360.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarCare360.Desktop.ViewModels"
        xmlns:helpers="clr-namespace:CarCare360.Desktop.Helpers"
        Title="CarCare 360"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource LightBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Стиль кнопок бокового меню -->
        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="Transparent" />
            <Setter Property="Foreground"              Value="White" />
            <Setter Property="FontSize"                Value="14" />
            <Setter Property="FontWeight"              Value="Regular" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding"                 Value="20,14" />
            <Setter Property="Height"                  Value="48" />
            <Setter Property="BorderThickness"         Value="0" />
            <Setter Property="Cursor"                  Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="4,0,0,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource PrimaryDarkBlueHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentOrangeBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка «Выйти» -->
        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
            <Setter Property="FontWeight"              Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Margin"                  Value="16,8,16,16" />
            <Setter Property="Background"              Value="{StaticResource AccentOrangeBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AccentOrangeHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Внешний Grid: колонки + оверлей тостов -->
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*"   />
        </Grid.ColumnDefinitions>

        <!-- ══ Боковое меню ════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBlueBrush}">
            <DockPanel>
                <!-- Логотип + пользователь (кликабельный → профиль) -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="CarCare 360"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White" Margin="16,24,16,12"/>

                    <Button Command="{Binding NavigateProfileCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Padding="16,10" Height="Auto" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <!-- Мини-аватар: Ellipse гарантирует круговой клиппинг -->
                            <Grid Width="36" Height="36" VerticalAlignment="Center">
                                <Ellipse Width="36" Height="36"
                                         Fill="{StaticResource AccentOrangeBrush}"/>
                                <!-- Инициалы (резерв) -->
                                <TextBlock Text="{Binding UserInitials}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSidebarAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Фото -->
                                <Ellipse Width="36" Height="36">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSidebarAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding SidebarAvatarSource}"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserShortName}"
                                           FontSize="13" Foreground="White"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding RoleName}"
                                           FontSize="10" Foreground="#B0BEC5"
                                           Margin="0,1,0,0"/>
                                <TextBlock Text="Открыть профиль →"
                                           FontSize="10" Foreground="#78909C"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Кнопка выхода (внизу) -->
                <Button DockPanel.Dock="Bottom"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource LogoutButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Выйти" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Навигационные пункты с иконками Segoe MDL2 Assets -->
                <StackPanel>
                    <Button Command="{Binding NavigateClientsCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsClientsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Клиенты" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCarsCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsCarsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE804;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Автомобили" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateOrdersCommand}"
                            Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Заказы" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateWarehouseCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsWarehouseVisible,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Склад" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateMechanicsCommand}"
                            Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE90D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Механики" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateReferencesCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsReferencesVisible,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Справочники" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateAuditCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsAuditVisible,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Аудит" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateReportsCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            Visibility="{Binding IsReportsVisible,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Width="16" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Отчёты" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Область контента с анимацией перехода ═══════════════════════ -->
        <helpers:AnimatedContentControl Grid.Column="1"
                                        Content="{Binding CurrentView}" />

        <!-- ══ Оверлей тостов (поверх всего, правый верхний угол) ══════════ -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2"
              IsHitTestVisible="False"
              Panel.ZIndex="9999"
              VerticalAlignment="Top"
              HorizontalAlignment="Right"
              Margin="0,12,12,0">
            <StackPanel x:Name="ToastContainer"
                        IsHitTestVisible="True"
                        Width="310"
                        VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Window>
