<Window x:Class="CarCare360.Desktop.Views.ClientOrderCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создать заявку на обслуживание"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource LightBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Заголовок -->
            <RowDefinition Height="Auto"/> <!-- Форма -->
            <RowDefinition Height="Auto"/> <!-- Ошибка -->
            <RowDefinition Height="Auto"/> <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBlueBrush}" Padding="24,18">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                           FontSize="22" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Создать заявку"
                               FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Мы свяжемся с вами для уточнения деталей"
                               FontSize="11" Foreground="#90CAF9" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1" Margin="24,20,24,4">

            <!-- Автомобиль -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Автомобиль *" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Cars}"
                          SelectedItem="{Binding SelectedCar}"
                          DisplayMemberPath="DisplayName"
                          FontSize="14" Height="36"
                          ToolTip="Выберите автомобиль для обслуживания"/>
                <!-- Подсказка если нет машин -->
                <TextBlock Text="У вас нет зарегистрированных автомобилей. Добавьте авто в разделе «Мой автомобиль»."
                           FontSize="11" Foreground="#E65100"
                           TextWrapping="Wrap" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Cars.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Желаемая дата -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Желаемая дата" Style="{StaticResource FieldLabel}"/>
                <DatePicker SelectedDate="{Binding ScheduledDate}"
                            FontSize="14" Height="36"
                            DisplayDateStart="{x:Static system:DateTime.Today}"
                            ToolTip="Укажите удобную дату (необязательно)"
                            xmlns:system="clr-namespace:System;assembly=mscorlib"/>
            </StackPanel>

            <!-- Описание проблемы -->
            <StackPanel Margin="0,0,0,4">
                <TextBlock Text="Описание проблемы" Style="{StaticResource FieldLabel}"/>
                <Border BorderBrush="{StaticResource BorderGrayBrush}"
                        BorderThickness="1" CornerRadius="8" Background="White">
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent"
                             FontSize="13" Padding="10,8"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="90" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             ToolTip="Опишите неисправность или желаемые работы"/>
                </Border>
            </StackPanel>

        </StackPanel>

        <!-- Сообщение об ошибке -->
        <Border Grid.Row="2" Margin="24,8,24,0"
                Background="#FFEBEE" CornerRadius="6" Padding="12,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,1,0,0" Padding="24,14" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}"
                        Style="{StaticResource NeutralButtonStyle}"
                        Content="Отмена" Margin="0,0,10,0"/>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Отправить заявку" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
