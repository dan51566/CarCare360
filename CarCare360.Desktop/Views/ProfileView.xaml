<UserControl x:Class="CarCare360.Desktop.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource LightBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════ Заголовок ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGrayBrush}"
                BorderThickness="0,0,0,1" Padding="28,18">
            <TextBlock Text="Профиль" FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryDarkBlueBrush}"/>
        </Border>

        <!-- ════ Контент ══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="780" Margin="32,28,32,28"
                        HorizontalAlignment="Center">

                <!-- ── Карточка: Аватар + имя ──────────────────────────────── -->
                <Border Background="White" CornerRadius="14" Padding="28"
                        BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                        Margin="0,0,0,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel Orientation="Horizontal">

                        <!-- Аватар + кнопки под ним -->
                        <StackPanel VerticalAlignment="Center">

                            <!-- Круг 96×96: Ellipse для надёжного кругового клиппинга -->
                            <Grid Width="96" Height="96">
                                <!-- Цветной фон (всегда виден) -->
                                <Ellipse Width="96" Height="96" Fill="{Binding AvatarBrush}"/>

                                <!-- Инициалы (скрыты когда загружено фото) -->
                                <TextBlock Text="{Binding Initials}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Фото в круге — Ellipse + ImageBrush = гарантированный круг -->
                                <Ellipse Width="96" Height="96">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding AvatarImageSource}"
                                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <!-- Кнопки под аватаром -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="0,10,0,0">
                                <Button Content="📷 Фото"
                                        Command="{Binding UploadAvatarCommand}"
                                        Style="{StaticResource NeutralButtonStyle}"
                                        FontSize="11" Padding="8,4"
                                        ToolTip="Загрузить фото с компьютера"/>
                                <Button Content="✕"
                                        Command="{Binding ClearAvatarCommand}"
                                        ToolTip="Удалить фото"
                                        Margin="4,0,0,0"
                                        Padding="6,4" FontSize="11">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- ФИО + роль + логин -->
                        <StackPanel Margin="28,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FullName}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBlueBrush}"/>
                            <Border Background="{StaticResource AccentOrangeBrush}"
                                    CornerRadius="10" Padding="12,4"
                                    HorizontalAlignment="Left" Margin="0,8,0,6">
                                <TextBlock Text="{Binding RoleName}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Логин: " FontSize="13" Foreground="#888"/>
                                <TextBlock Text="{Binding CurrentLogin}"
                                           FontSize="13" FontFamily="Consolas"
                                           Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Карточка: Личные данные ─────────────────────────────── -->
                <Border Background="White" CornerRadius="14" Padding="28"
                        BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                        Margin="0,0,0,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Личные данные"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="ФИО *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Телефон" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Email" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"/>

                        <Grid>
                            <TextBlock Text="{Binding InfoStatus}"
                                       FontSize="12" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InfoStatus[0]}" Value="✓">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="💾  Сохранить"
                                    Command="{Binding SaveInfoCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Карточка: Изменить логин ────────────────────────────── -->
                <Border Background="White" CornerRadius="14" Padding="28"
                        BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                        Margin="0,0,0,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Изменить логин"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Новый логин *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewLogin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Текущий пароль *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <Border BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,14">
                            <PasswordBox x:Name="PwdLoginCurrent"
                                         PasswordChanged="PwdLoginCurrent_Changed"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="10,9" FontSize="13"/>
                        </Border>

                        <Grid>
                            <TextBlock Text="{Binding LoginStatus}"
                                       FontSize="12" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LoginStatus[0]}" Value="✓">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="✓  Применить"
                                    Command="{Binding SaveLoginCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Карточка: Изменить пароль ───────────────────────────── -->
                <Border Background="White" CornerRadius="14" Padding="28"
                        BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1"
                        Margin="0,0,0,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Изменить пароль"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryDarkBlueBrush}"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Текущий пароль *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <Border BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,14">
                            <PasswordBox x:Name="PwdOld"
                                         PasswordChanged="PwdOld_Changed"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="10,9" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Новый пароль *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <Border BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,14">
                            <PasswordBox x:Name="PwdNew"
                                         PasswordChanged="PwdNew_Changed"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="10,9" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Подтвердить новый пароль *" FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <Border BorderBrush="{StaticResource BorderGrayBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,14">
                            <PasswordBox x:Name="PwdConfirm"
                                         PasswordChanged="PwdConfirm_Changed"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="10,9" FontSize="13"/>
                        </Border>

                        <Grid>
                            <TextBlock Text="{Binding PasswordStatus}"
                                       FontSize="12" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStatus[0]}" Value="✓">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="🔒  Сменить пароль"
                                    Command="{Binding SavePasswordCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
