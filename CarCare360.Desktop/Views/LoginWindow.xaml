<Window x:Class="CarCare360.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarCare360.Desktop.ViewModels"
        Title="CarCare 360 — Авторизация"
        Height="520" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#12123A"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Стиль тёмного поля ввода -->
        <Style x:Key="DarkInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль тёмного поля пароля -->
        <Style x:Key="DarkPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ═══ Слой 0: Canvas с blob-анимацией ═══ -->
        <Canvas x:Name="BlobCanvas"
                Panel.ZIndex="0"
                ClipToBounds="True"
                IsHitTestVisible="False">

            <!-- Blob 1 — синий -->
            <Ellipse Width="260" Height="260"
                     Fill="#3949AB" Opacity="0.55">
                <Ellipse.Effect><BlurEffect Radius="45" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale1" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans1" X="-60" Y="-60" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Blob 2 — оранжевый -->
            <Ellipse Width="200" Height="200"
                     Fill="#FF6D00" Opacity="0.50">
                <Ellipse.Effect><BlurEffect Radius="38" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale2" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans2" X="280" Y="30" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Blob 3 — фиолетовый -->
            <Ellipse Width="230" Height="230"
                     Fill="#7B1FA2" Opacity="0.45">
                <Ellipse.Effect><BlurEffect Radius="50" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale3" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans3" X="160" Y="300" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Blob 4 — тёмно-синий -->
            <Ellipse Width="180" Height="180"
                     Fill="#1565C0" Opacity="0.60">
                <Ellipse.Effect><BlurEffect Radius="32" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale4" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans4" X="-20" Y="340" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Blob 5 — янтарный -->
            <Ellipse Width="150" Height="150"
                     Fill="#FF8F00" Opacity="0.42">
                <Ellipse.Effect><BlurEffect Radius="28" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale5" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans5" X="310" Y="260" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Blob 6 — индиго -->
            <Ellipse Width="210" Height="210"
                     Fill="#283593" Opacity="0.48">
                <Ellipse.Effect><BlurEffect Radius="42" /></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BlobScale6" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="BlobTrans6" X="100" Y="-30" />
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- ═══ Слой 1: Карточка формы входа ═══ -->
        <Border Panel.ZIndex="1"
                Background="#FAFAFA"
                CornerRadius="20"
                Width="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40,36">
            <StackPanel>

                <!-- Логотип и заголовок -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock Text="🔧"
                               FontSize="28"
                               FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="CarCare 360"
                               FontSize="26"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="#12123A" />
                </StackPanel>

                <TextBlock Text="Авторизация"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="#888"
                           Margin="0,0,0,28" />

                <!-- ─── Поле логина ─── -->
                <Border Background="#252535"
                        CornerRadius="10"
                        Padding="14,0"
                        Height="48"
                        Margin="0,0,0,14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1.5" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#FF6B00" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="👤"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="#888" />
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource DarkInputStyle}"
                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />
                        <!-- Placeholder текст логина -->
                        <TextBlock Grid.Column="2"
                                   Text="Введите логин"
                                   FontSize="14"
                                   Foreground="#666"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <!-- По умолчанию скрыт (когда поле заполнено) -->
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <!-- Показываем placeholder только когда поле пустое -->
                                        <DataTrigger Binding="{Binding Login}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ─── Поле пароля ─── -->
                <Border Background="#252535"
                        CornerRadius="10"
                        Padding="14,0"
                        Height="48"
                        Margin="0,0,0,18">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1.5" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#FF6B00" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🔒"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="#888" />
                        <PasswordBox Grid.Column="2"
                                     x:Name="PasswordInput"
                                     Style="{StaticResource DarkPasswordStyle}"
                                     PasswordChanged="PasswordInput_PasswordChanged" />
                        <!-- Placeholder текст пароля (управляется из code-behind) -->
                        <TextBlock Grid.Column="2"
                                   x:Name="PasswordPlaceholder"
                                   Text="Введите пароль"
                                   FontSize="14"
                                   Foreground="#666"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Visible" />
                    </Grid>
                </Border>

                <!-- ─── Запомнить меня ─── -->
                <CheckBox IsChecked="{Binding RememberMe}"
                          Margin="0,0,0,14"
                          Cursor="Hand"
                          VerticalAlignment="Center">
                    <CheckBox.Template>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal">
                                <!-- Кастомный чекбокс в тёмном стиле -->
                                <Border x:Name="box"
                                        Width="18" Height="18"
                                        CornerRadius="4"
                                        BorderThickness="1.5"
                                        BorderBrush="#555"
                                        Background="Transparent"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                    <TextBlock x:Name="check"
                                               Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#FF6B00"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Border>
                                <TextBlock Text="Запомнить меня"
                                           FontSize="13" Foreground="#AAAAAA"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="box"   Property="BorderBrush"  Value="#FF6B00"/>
                                    <Setter TargetName="check" Property="Visibility"   Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="box" Property="BorderBrush" Value="#FF6B00"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </CheckBox.Template>
                </CheckBox>

                <!-- ─── Сообщение об ошибке (видно только при непустом ErrorMessage) ─── -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E53935"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <!-- По умолчанию виден, но ErrorMessage пуст при старте -->
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <!-- Скрываем когда нет ошибки -->
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- ─── Кнопка «Войти» ─── -->
                <Button Content="Войти"
                        Command="{Binding LoginCommand}"
                        IsDefault="True"
                        Height="46"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder"
                                    Background="#FF6B00"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E65100" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#BF360C" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#BDBDBD" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Ссылка на регистрацию -->
                <Button Content="Нет аккаунта? Зарегистрироваться"
                        Command="{Binding RegisterCommand}"
                        Cursor="Hand" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                       Foreground="#888" FontSize="12"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="tb" Property="Foreground" Value="#FF6B00"/>
                                    <Setter TargetName="tb" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
