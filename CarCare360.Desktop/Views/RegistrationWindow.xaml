<Window x:Class="CarCare360.Desktop.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CarCare 360 — Регистрация"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#12123A">

    <Window.Resources>
        <Style x:Key="DarkInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Стиль чипа выбора роли -->
        <Style x:Key="RoleChipStyle" TargetType="Button">
            <Setter Property="Height"       Value="40"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FAFAFA" CornerRadius="20"
            Width="380" Padding="40,36,40,36"
            VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel>

            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <TextBlock Text="🔧" FontSize="28" FontFamily="Segoe UI Emoji"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="CarCare 360" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#12123A"/>
            </StackPanel>
            <TextBlock Text="Регистрация" FontSize="13" HorizontalAlignment="Center"
                       Foreground="#888" Margin="0,0,0,22"/>

            <!-- Выбор роли: Клиент / Механик -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="👤  Клиент"
                        Click="ClientRole_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource RoleChipStyle}">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMechanic}" Value="False">
                                    <Setter Property="Background" Value="#1A237E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="🔧  Механик"
                        Click="MechanicRole_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource RoleChipStyle}">
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMechanic}" Value="True">
                                    <Setter Property="Background" Value="#FF6B00"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Информация о роли -->
            <TextBlock Text="{Binding RoleInfo}" FontSize="11"
                       HorizontalAlignment="Center" Foreground="#888"
                       Margin="0,0,0,16" TextWrapping="Wrap"/>

            <!-- ФИО -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FieldBorderStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="📝" FontFamily="Segoe UI Emoji" FontSize="15"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <TextBox Grid.Column="2" Style="{StaticResource DarkInputStyle}"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="Полное имя (ФИО)"
                               FontSize="14" Foreground="#666" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FullName}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Логин -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FieldBorderStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="👤" FontFamily="Segoe UI Emoji" FontSize="15"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <TextBox Grid.Column="2" Style="{StaticResource DarkInputStyle}"
                             Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="Логин"
                               FontSize="14" Foreground="#666" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Login}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Пароль -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FieldBorderStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔒" FontFamily="Segoe UI Emoji" FontSize="15"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <PasswordBox Grid.Column="2" x:Name="PwdBox"
                                 Style="{StaticResource DarkPasswordStyle}"
                                 PasswordChanged="PwdBox_Changed"/>
                    <TextBlock Grid.Column="2" x:Name="PwdPlaceholder"
                               Text="Пароль (мин. 6 символов)"
                               FontSize="14" Foreground="#666" VerticalAlignment="Center"
                               IsHitTestVisible="False" Visibility="Visible"/>
                </Grid>
            </Border>

            <!-- Подтверждение пароля -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FieldBorderStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔒" FontFamily="Segoe UI Emoji" FontSize="15"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <PasswordBox Grid.Column="2" x:Name="ConfirmPwdBox"
                                 Style="{StaticResource DarkPasswordStyle}"
                                 PasswordChanged="ConfirmPwdBox_Changed"/>
                    <TextBlock Grid.Column="2" x:Name="ConfirmPwdPlaceholder"
                               Text="Подтвердите пароль"
                               FontSize="14" Foreground="#666" VerticalAlignment="Center"
                               IsHitTestVisible="False" Visibility="Visible"/>
                </Grid>
            </Border>

            <!-- Телефон (необязательно) -->
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FieldBorderStyle}">
                        <Setter Property="Margin" Value="0,0,0,16"/>
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF6B00"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="📱" FontFamily="Segoe UI Emoji" FontSize="15"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <TextBox Grid.Column="2" Style="{StaticResource DarkInputStyle}"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="Телефон (необязательно)"
                               FontSize="14" Foreground="#666" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Phone}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Ошибка -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935"
                       FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Кнопка регистрации -->
            <Button Command="{Binding RegisterCommand}"
                    Content="Зарегистрироваться"
                    Height="46" FontSize="15" FontWeight="SemiBold"
                    Foreground="White" Cursor="Hand" Margin="0,0,0,12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#FF6B00" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E65100"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Назад -->
            <Button Content="← Уже есть аккаунт? Войти"
                    Command="{Binding BackCommand}"
                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                    FontSize="12" Foreground="#888" HorizontalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                   Foreground="#888" FontSize="12"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Foreground" Value="#FF6B00"/>
                                <Setter TargetName="tb" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Border>
</Window>
