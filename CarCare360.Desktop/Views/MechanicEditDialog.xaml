<Window x:Class="CarCare360.Desktop.Views.MechanicEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource LightBackgroundBrush}">

    <Border Padding="28,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Title}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryDarkBlueBrush}"
                       Margin="0,0,0,20" />

            <!-- ФИО -->
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Text="ФИО *" FontSize="12" Foreground="#555555" Margin="0,0,0,4" />
                <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Логин (только для нового) -->
            <StackPanel Grid.Row="2" Margin="0,0,0,14">
                <TextBlock FontSize="12" Foreground="#555555" Margin="0,0,0,4">
                    <Run Text="Логин" />
                    <Run Text=" *" Foreground="{StaticResource ErrorRedBrush}">
                        <Run.Style>
                            <Style TargetType="Run">
                                <Setter Property="Foreground" Value="{StaticResource ErrorRedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewMechanic}" Value="False">
                                        <Setter Property="Foreground" Value="Transparent" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Run.Style>
                    </Run>
                </TextBlock>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource ThemedTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewMechanic}" Value="False">
                                    <Setter Property="IsReadOnly" Value="True" />
                                    <Setter Property="Background" Value="#F0F0F0" />
                                    <Setter Property="Foreground" Value="#888888" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>

            <!-- Пароль (только для нового) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,14">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNewMechanic}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Пароль *" FontSize="12" Foreground="#555555" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordInput"
                             Style="{StaticResource ThemedPasswordBoxStyle}"
                             PasswordChanged="PasswordInput_PasswordChanged" />
            </StackPanel>

            <!-- Специализация + Квалификация -->
            <Grid Grid.Row="4" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Специализация" FontSize="12" Foreground="#555555" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Specializations}"
                              SelectedItem="{Binding SelectedSpecialization}"
                              DisplayMemberPath="Name"
                              Padding="10,8" FontSize="13"
                              VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Квалификация" FontSize="12" Foreground="#555555" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                             Text="{Binding QualificationLevel, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="50" />
                </StackPanel>
            </Grid>

            <!-- Дата найма + Активен -->
            <Grid Grid.Row="5" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Дата найма (ДД.ММ.ГГГГ)" FontSize="12" Foreground="#555555" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ThemedTextBoxStyle}"
                             Text="{Binding HireDateStr, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="10" />
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text=" " FontSize="12" Margin="0,0,0,4" />
                    <CheckBox Content="Активен"
                              IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center"
                              FontSize="13">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewMechanic}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </StackPanel>
            </Grid>

            <!-- Ошибка -->
            <Border Grid.Row="6" Background="#FFEBEE" CornerRadius="4"
                    Padding="12,8" Margin="0,0,0,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontSize="13" TextWrapping="Wrap" />
            </Border>

            <!-- Кнопки -->
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Отмена" Command="{Binding CancelCommand}" Height="40" FontSize="14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBlueBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBlueBrush}" />
                            <Setter Property="BorderThickness" Value="1.5" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8EAF6" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" Content="  Сохранить  "
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40" FontSize="14" />
            </Grid>
        </Grid>
    </Border>
</Window>
