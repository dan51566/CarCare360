# ============================================================================
#  CarCare360 — образ одноразовой инициализации базы данных.
#  Основан на образе с утилитой sqlcmd. SQL-скрипты схемы и скрипт init.sh
#  КОПИРУЮТСЯ внутрь образа на этапе сборки (а не монтируются во время выполнения),
#  чтобы не зависеть от bind-mount хостового пути — в частности, путей с кириллицей,
#  которые Docker Desktop не умеет монтировать.
#
#  Контекст сборки — корень репозитория (см. docker-compose.yml: context: .),
#  поэтому пути COPY указаны относительно корня. Скрипты схемы НЕ модифицируются
#  в репозитории: перекодировка ниже выполняется над КОПИЕЙ внутри образа.
# ============================================================================
FROM mcr.microsoft.com/mssql-tools:latest

# Существующие скрипты схемы (применяются init.sh без изменений их логики).
COPY SQL/ /sql/

# Скрипты в репозитории — UTF-8 без BOM. У используемой версии sqlcmd нет рабочей
# опции выбора кодовой страницы ввода (-f), поэтому конвертируем копию скриптов в
# UTF-16LE с BOM: sqlcmd автоматически распознаёт BOM и корректно читает кириллицу
# (комментарии и строковые литералы — например, имена ролей 'Администратор' и т.п.).
RUN set -e; for f in /sql/*.sql; do \
      { printf '\377\376'; iconv -f UTF-8 -t UTF-16LE "$f"; } > "$f.u16"; \
      mv "$f.u16" "$f"; \
    done

# Скрипт инициализации (на хосте — с LF-окончаниями строк, см. .gitattributes).
COPY docker/db-init/init.sh /init/init.sh

ENTRYPOINT ["/bin/bash", "/init/init.sh"]
