# ============================================================================
#  CarCare360 — шаблон переменных окружения для развёртывания серверной части.
#  Скопируйте этот файл в .env и подставьте реальные значения.
#  Файл .env содержит секреты и НЕ должен попадать в репозиторий (см. .gitignore).
# ============================================================================

# ─── База данных (Microsoft SQL Server) ─────────────────────────────────────
# Пароль системного администратора SQL Server (учётная запись sa).
# Требования SQL Server к паролю: не короче 8 символов и минимум 3 категории
# из 4 (заглавные, строчные, цифры, спецсимволы). ОБЯЗАТЕЛЬНО смените значение.
MSSQL_SA_PASSWORD=CHANGE_me_Strong_Pass123!

# Редакция SQL Server: Express (как локальный .\SQLEXPRESS) | Developer | Standard.
MSSQL_PID=Express

# Сортировка/кодовая страница SQL Server. Cyrillic_General_CI_AS (CP1251) — как на
# исходном .\SQLEXPRESS; нужна для корректного хранения кириллических литералов без
# префикса N. Применяется только при первичной инициализации тома данных.
MSSQL_COLLATION=Cyrillic_General_CI_AS

# Порт SQL Server, публикуемый на хост (для внешних утилит, напр. SSMS).
# Внутри сети compose сервисы всегда обращаются к db по порту 1433.
DB_PORT=1433

# ─── Серверный REST API ─────────────────────────────────────────────────────
# Порт, на котором API доступен на хосте. Десктоп и мобильное приложение
# подключаются к этому порту (по умолчанию 5009 — как и при локальном запуске).
API_PORT=5009

# Окружение ASP.NET Core: Development (доступен Swagger /swagger) | Production.
ASPNETCORE_ENVIRONMENT=Development

# Секрет для подписи JWT-токенов. Длинная случайная строка (минимум 32 символа).
# ОБЯЗАТЕЛЬНО смените значение перед использованием.
JWT_SIGNING_KEY=CHANGE-ME-please-use-a-long-random-secret-key-0123456789

# ─── Строка подключения API к БД ────────────────────────────────────────────
# Отдельно задавать НЕ требуется: docker-compose.yml собирает её автоматически
# из MSSQL_SA_PASSWORD в виде:
#   Server=db,1433;Database=CarCare360;User Id=sa;Password=<MSSQL_SA_PASSWORD>;TrustServerCertificate=True;Encrypt=False
